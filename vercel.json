{
  "version": 2,
  "buildCommand": "cd .. && turbo run build --filter=@supernal-interface/docs-site",
  "installCommand": "echo '//npm.pkg.github.com/:_authToken=${NPM_TOKEN}' >> ../.npmrc && npm --prefix=.. ci",
  "env": {
    "NODE_ENV": "production",
    "NEXT_PUBLIC_ENABLE_ANALYTICS": "true",
    "NEXT_PUBLIC_CONTACT_EMAIL": "hello@supernal.ai",
    "NEXT_PUBLIC_GLASS_MODE": "true"
  }
}
