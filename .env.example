# ============================================
# Authentication Configuration (REQUIRED for protected routes)
# ============================================
# Security Model: FAIL CLOSED
# - Missing any of these = protected routes inaccessible
# - In production: missing vars = build failure
# - This is intentional security behavior

# Auth Secret - encrypts cookies and tokens
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
# Callback URL: https://your-domain.com/api/auth/callback/github (or http://localhost:3000/api/auth/callback/github for local)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: Restrict access to specific email addresses (comma-separated)
# If not set, all GitHub users who authenticate can access
# Example: alice@example.com,bob@example.com
ALLOWED_EMAILS=

# ============================================
# Supernal TTS Configuration
# ============================================

# Supernal TTS Configuration
NEXT_PUBLIC_TTS_API_URL=http://localhost:3030
NEXT_PUBLIC_TTS_API_KEY=your-tts-api-key-here

# Chat Bubble Glass Mode (true = translucent glass effect, false = solid background)
# Default: true
# Note: Users can customize opacity level (light/medium/heavy) via the chat settings menu.
# Settings are persisted in browser localStorage.
NEXT_PUBLIC_GLASS_MODE=true

# Hero Variant Selection (a, b, c, d)
# Controls which landing page hero variant is displayed
# - a = Current cycling (default) - "Agentify your React App/Website/Future"
# - b = Problem-solution with typewriter - "Make your App an Agent for your Customers" + happiness
# - c = User-benefit with stagger animation - "Make your App an Agent" + delight users
# - d = Developer-first with code reveal - "Agentify your React App" + decorator messaging
#
# Note: Can be overridden with URL query parameter: ?variant=b
# Default: a
NEXT_PUBLIC_HERO_VARIANT=a

# ============================================
# Analytics Configuration
# ============================================

# Google Tag Manager
# Get your container ID from: https://tagmanager.google.com
# Format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_CONTAINER_ID=

# PostHog Analytics
# Signup at: https://posthog.com
# Get your API key from: Project Settings → API Keys
# Format: phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# PostHog Session Replay (Privacy-Sensitive)
# Enables recording of user sessions for debugging and UX analysis
# All inputs are masked by default for privacy
# Set to 'true' to enable (requires PostHog Plus plan)
# Default: false
NEXT_PUBLIC_POSTHOG_SESSION_REPLAY=false
